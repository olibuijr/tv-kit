  case $mode in ruv|ruv2|off) ;; *) echo 'tvctl: kit fullscreen accepts ruv, ruv2, or off' >&2; exit 64 ;; esac
  local script='const mode = Bun.env.TVCTL_FULLSCREEN;
let ws;
const fail = message => { console.error(message); try { ws?.close(); } catch {} process.exit(1); };
const watchdog = setTimeout(() => fail("TV Kit WebSocket timeout"), 5000);
ws = new WebSocket("ws://127.0.0.1:3110/ws", { headers: { Origin: "http://127.0.0.1:3112" } });
ws.onerror = () => fail("TV Kit WebSocket connection failed");
ws.onopen = () => {
  if (mode !== "off") ws.send(JSON.stringify({ type: "command", action: "ruv-channel", value: mode }));
  setTimeout(() => ws.send(JSON.stringify({ type: "command", action: "fullscreen", value: mode !== "off" })), mode === "off" ? 0 : 150);
  setTimeout(async () => {
    try {
      const state = (await (await fetch("http://127.0.0.1:3110/health")).json()).state;
      const ok = state.media.fullscreen === (mode !== "off") && (mode === "off" || state.media.id === `ruv-channel-${mode}`);
      console.log(`fullscreen=${state.media.fullscreen ? "on" : "off"} media=${state.media.id} status=${state.media.status}`);
      clearTimeout(watchdog);
