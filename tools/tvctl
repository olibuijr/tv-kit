kit_playback() {
  local mode=${1:-state}; shift || true
  case $mode in
    state)
      (($# == 0)) || { echo 'tvctl: kit playback state accepts no arguments' >&2; exit 64; }
      remote_argv ~/.bun/bin/bun -e 'const health=await (await fetch("http://127.0.0.1:3110/health")).json(); const current=health.state; console.log(JSON.stringify({playing:current.playing,id:current.media.id,title:current.media.title,engine:current.media.engine||"none",position:current.media.currentTime,status:current.media.status,clients:health.clients}));'
      return
      ;;
    search)
      (($#)) || { echo 'tvctl: kit playback search requires a title query' >&2; exit 64; }
      local query=$* escaped
      escaped=${query//\'/\'\'}
      remote_argv sqlite3 "/home/$user/$kit_home/data/tv-kit.sqlite" "SELECT id,title,original_title FROM deildu_items WHERE title LIKE '%$escaped%' OR original_title LIKE '%$escaped%' ORDER BY id;"
      return
      ;;
    stop|play)
      (($# == 0)) || { echo "tvctl: kit playback $mode accepts no arguments" >&2; exit 64; }
      ;;
    deildu)
      (($# == 1)) && [[ $1 =~ ^[1-9][0-9]*$ ]] || { echo 'tvctl: kit playback deildu requires one positive item id' >&2; exit 64; }
      ;;
    *) echo 'tvctl: kit playback accepts state, stop, play, search QUERY, or deildu ITEM_ID' >&2; exit 64 ;;
  esac
  local value=${1:-0}
  local script='const mode = Bun.env.TVCTL_PLAYBACK;
const value = Number(Bun.env.TVCTL_PLAYBACK_VALUE || 0);
let ws;
let baseline;
const abort = () => { try { if (ws?.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type: "command", action: "stop-playback", label: "tvctl timeout" })); } catch {} };
const fail = (message, stop = false) => { console.error(message); if (stop) abort(); setTimeout(() => { try { ws?.close(); } catch {} process.exit(1); }, stop ? 200 : 0); };
const state = async () => (await (await fetch("http://127.0.0.1:3110/health")).json()).state;
const done = current => { console.log(JSON.stringify({ playing: current.playing, id: current.media.id, title: current.media.title, engine: current.media.engine || "none", position: current.media.currentTime, status: current.media.status })); ws?.close(); setTimeout(() => process.exit(0), 100); };
const watchdog = setTimeout(() => fail("TV Kit playback produced no frames", true), 25000);
const send = () => ws.send(JSON.stringify(mode === "deildu"
  ? { type: "command", action: "deildu-play", value, label: `tvctl ${mode}` }
  : mode === "stop"
    ? { type: "command", action: "stop-playback", label: `tvctl ${mode}` }
    : { type: "command", action: "set-playing", value: true, label: `tvctl ${mode}` }));
const verify = async (attempt = 0) => {
  const current = await state();
  if (mode === "stop" && !current.playing || mode === "play" && current.playing && current.media.src) { clearTimeout(watchdog); return done(current); }
  if (mode === "deildu" && current.media.id === `deildu-${value}`) {
    if (baseline === undefined) baseline = current.media.currentTime;
    if (["mpv", "browser"].includes(current.media.engine) && current.media.status === "ready" && current.media.currentTime > baseline + 0.5) { clearTimeout(watchdog); return done(current); }
    if (current.media.status === "error") return fail("TV Kit playback failed", true);
  }
  if (attempt >= 11) return fail("TV Kit playback produced no frames", true);
  setTimeout(() => verify(attempt + 1), 2000);
};
ws = new WebSocket("ws://127.0.0.1:3110/ws?client=tvctl", { headers: { Origin: "http://127.0.0.1:3112" } });
ws.onerror = () => fail("TV Kit WebSocket connection failed");
ws.onopen = async () => {
  const before = await state();
  if (mode === "stop" && !before.playing || mode === "play" && before.playing) return done(before);
  send();
  setTimeout(() => verify(), mode === "deildu" ? 1000 : 400);
};'
  remote_argv env TVCTL_PLAYBACK="$mode" TVCTL_PLAYBACK_VALUE="$value" ~/.bun/bin/bun -e "$script"
}

mpv_control() {
  local action=${1:-tracks}; shift || true
  case $action in
    tracks)
      (($# == 0)) || { echo 'tvctl: mpv tracks accepts no arguments' >&2; exit 64; }
      ;;
    audio|subtitle)
      (($# == 1)) && [[ $1 == auto || $1 == off || $1 =~ ^[1-9][0-9]*$ ]] || {
        echo "tvctl: mpv $action requires a positive track ID, auto, or off" >&2
        exit 64
      }
      ;;
    *) echo 'tvctl: mpv accepts tracks, audio ID|auto|off, or subtitle ID|auto|off' >&2; exit 64 ;;
  esac
  local value=${1:-}
  local script='import { existsSync } from "node:fs";
const action = Bun.env.TVCTL_MPV_ACTION || "tracks";
const raw = Bun.env.TVCTL_MPV_VALUE || "";
const socketPath = ["/run/user/1000/tv-direct-mpv.sock", "/run/user/1000/tv-kit-mpv.sock"].find(existsSync);
if (!socketPath) { console.error("tvctl: no active mpv IPC socket"); process.exit(1); }
let requestId = 0;
let setId = 0;
const commands = [];
if (action !== "tracks") {
  const property = action === "audio" ? "aid" : "sid";
  const value = raw === "off" ? "no" : raw === "auto" ? "auto" : Number(raw);
  setId = ++requestId;
  commands.push({ command: ["set_property", property, value], request_id: setId });
}
const tracksId = ++requestId;
const audioId = ++requestId;
const subtitleId = ++requestId;
commands.push(
  { command: ["get_property", "track-list"], request_id: tracksId },
  { command: ["get_property", "aid"], request_id: audioId },
  { command: ["get_property", "sid"], request_id: subtitleId },
);
const child = Bun.spawn({
  cmd: ["timeout", "2", "socat", "-", `UNIX-CONNECT:${socketPath}`],
  stdin: "pipe", stdout: "pipe", stderr: "pipe",
});
child.stdin.write(commands.map(command => JSON.stringify(command)).join("\n") + "\n");
child.stdin.end();
const output = await new Response(child.stdout).text();
await child.exited;
const responses = new Map();
for (const line of output.split("\n")) {
  try { const value = JSON.parse(line); if (value.request_id) responses.set(value.request_id, value); } catch {}
}
if (setId && responses.get(setId)?.error !== "success") {
  console.error(`tvctl: mpv rejected ${action} track ${raw}: ${responses.get(setId)?.error || "no response"}`);
  process.exit(1);
}
const tracksResponse = responses.get(tracksId);
if (tracksResponse?.error !== "success" || !Array.isArray(tracksResponse.data)) {
  console.error(`tvctl: could not read mpv tracks: ${tracksResponse?.error || "no response"}`);
  process.exit(1);
}
const tracks = tracksResponse.data;
const audio = tracks.filter(track => track.type === "audio").map(track => ({
  id: track.id, language: track.lang || "", title: track.title || "", codec: track.codec || "",
  channels: track["audio-channels"] || null, selected: Boolean(track.selected),
}));
const subtitles = tracks.filter(track => track.type === "sub").map(track => ({
  id: track.id, language: track.lang || "", title: track.title || "", codec: track.codec || "",
  forced: Boolean(track.forced), selected: Boolean(track.selected),
}));
const selectedAudio = responses.get(audioId)?.data;
const selectedSubtitle = responses.get(subtitleId)?.data;
console.log(JSON.stringify({
  socket: socketPath,
  selectedAudio: selectedAudio === false ? "off" : selectedAudio,
  selectedSubtitle: selectedSubtitle === false ? "off" : selectedSubtitle,
  audio,
  subtitles,
}));'
	remote_argv env TVCTL_MPV_ACTION="$action" TVCTL_MPV_VALUE="$value" ~/.bun/bin/bun -e "$script"
}

