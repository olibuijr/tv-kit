    if (baseline === undefined) baseline = current.media.currentTime;
    if (["mpv", "browser"].includes(current.media.engine) && current.media.status === "ready" && current.media.currentTime > baseline + 0.5) { clearTimeout(watchdog); return done(current); }
    if (current.media.status === "error") return fail("TV Kit playback failed", true);
  }
  if (attempt >= 18) return fail("TV Kit playback produced no frames", true);
  setTimeout(() => verify(attempt + 1), 2000);
};
ws = new WebSocket("ws://127.0.0.1:3110/ws?client=tvctl", { headers: { Origin: "http://127.0.0.1:3112" } });
ws.onerror = () => fail("TV Kit WebSocket connection failed");
ws.onopen = () => { ws.send(JSON.stringify({ type: "command", action: "public-torrent-play", value: hash, label: "tvctl public" })); setTimeout(() => verify(), 1500); };'
      remote_argv env TVCTL_PUBLIC_HASH="$hash" ~/.bun/bin/bun -e "$script"
      ;;
    stop)
      (($# == 0)) || { echo 'tvctl: public stop accepts no arguments' >&2; exit 64; }
      kit_playback stop
      ;;
    *) echo 'tvctl: public accepts search QUERY, list [N], scrape, state, play HASH, or stop' >&2; exit 64 ;;
  esac
}

tv_snapshot() {
  (($# == 0)) || { echo 'tvctl: snapshot accepts no arguments' >&2; exit 64; }
  local script='import { freemem, hostname, loadavg, totalmem, uptime } from "node:os";
const command = value => {
  const result = Bun.spawnSync(["bash", "-lc", value], { stdout: "pipe", stderr: "pipe" });
  return { ok: result.exitCode === 0, output: result.stdout.toString().trim() };
};
const serviceNames = ["tvserverd.service", "tv-remote.service", "tv-frame.service", "tvserverd-radioscraper.timer"];
const shown = command("XDG_RUNTIME_DIR=/run/user/1000 systemctl --user show " + serviceNames.join(" ") + " -p Id -p ActiveState -p UnitFileState --no-pager").output;
const services = shown.split(/\n\s*\n/).filter(Boolean).map(block => Object.fromEntries(block.split("\n").map(line => line.split(/=(.*)/s).slice(0, 2))));
let health = null;
const endpointEntries = await Promise.all([["server", "http://127.0.0.1:3110/health"], ["remote", "http://127.0.0.1:3112/"]].map(async ([name, url]) => {
  try {
    const response = await fetch(url, { signal: AbortSignal.timeout(1500) });
    if (name === "server" && response.ok) health = await response.json();
    return [name, { ok: response.ok, status: response.status }];
  } catch (error) {
    return [name, { ok: false, error: String(error) }];
  }
}));
const endpoints = Object.fromEntries(endpointEntries);
const media = health?.state?.media || {};
const count = name => Number(command("pgrep -cx " + name).output || 0);
console.log(JSON.stringify({
  system: { hostname: hostname(), uptimeSeconds: Math.round(uptime()), loadAverage: loadavg(), memoryBytes: { total: totalmem(), free: freemem() } },
  endpoints,
  services,
  playback: health ? { playing: Boolean(health.state?.playing), id: media.id || "", title: media.title || "", engine: media.engine || "none", status: media.status || "", position: media.currentTime || 0, duration: media.duration || 0, clients: health.clients || 0 } : null,
  processes: { mpv: count("mpv"), aria2c: count("aria2c"), chrome: count("chrome"), stremio: count("stremio") },
}));'
  remote_argv ~/.bun/bin/bun -e "$script"
}

remote_screenshot_path=
cleanup_screenshot() {
  [[ -n $remote_screenshot_path ]] || return 0
  remote_argv rm -f "$remote_screenshot_path" >/dev/null 2>&1 || true
  remote_screenshot_path=
}

case ${1:-help} in
  help|-h|--help) usage ;;
  kit)
    shift
    sub=${1:-status}; shift || true
    case $sub in
      sync|deploy) kit_sync "$*" ;;
      setup) kit_setup "$*" ;;
      golfbox-env) kit_golfbox_env "$@" ;;
      status) kit_status ;;
      verify) (($# == 0)) || { echo 'tvctl: kit verify accepts no arguments' >&2; exit 64; }; kit_verify ;;
      check) (($# <= 1)) || { echo 'tvctl: kit check accepts warnings only' >&2; exit 64; }; kit_check "${1:-}" ;;
      test) kit_test "$@" ;;
      frame)
        frame_action=${1:-health}; shift || true
        case $frame_action in
          build) kit_frame_build "$@" ;;
          test) kit_frame_test "$@" ;;
          deploy) kit_frame_deploy "$@" ;;
          health) kit_frame_health "$@" ;;
          verify) kit_frame_verify "$@" ;;
          *) echo 'tvctl: kit frame accepts build, test, health, or verify' >&2; exit 64 ;;
        esac
        ;;
      fullscreen) kit_fullscreen "$@" ;;
      playback) kit_playback "$@" ;;
      epg)
        epg_action=${1:-status}; shift || true
        case $epg_action in
          status) (($# == 0)) || { echo 'tvctl: kit epg status accepts no arguments' >&2; exit 64; }; kit_epg_status ;;
          sync) (($# == 0)) || { echo 'tvctl: kit epg sync accepts no arguments' >&2; exit 64; }; kit_epg_sync ;;
          *) echo 'tvctl: kit epg accepts status or sync' >&2; exit 64 ;;
        esac
        ;;
      restart) kit_restart "$@" ;;
      logs) kit_logs "$@" ;;
      archive) kit_archive "$*" ;;
      *) echo "tvctl: unknown kit command: $sub" >&2; usage >&2; exit 64 ;;
    esac
    ;;
  mpv)
    shift
    mpv_control "$@"
    ;;
  deildu)
    shift
    deildu_query "$@"
    ;;
  public)
    shift
    public_torrent "$@"
    ;;
  snapshot)
    shift
    tv_snapshot "$@"
    ;;
  doctor)
    printf 'target=%s\n' "$target"
    ip route get "$host" 2>/dev/null || { echo 'route=unreachable'; exit 2; }
    remote 'test "$(cat /etc/hostname)" = tv && echo hostname=tv || { echo hostname-mismatch; exit 3; }; printf "ssh=ok\n"; systemctl is-active NetworkManager sddm; loginctl list-sessions --no-legend' || {
      rc=$?
      echo "ssh=unreachable-or-unauthorized (exit=$rc)" >&2
      exit "$rc"
    }
    ;;
  status)
    remote 'printf "host=%s\n" "$(cat /etc/hostname)"; uptime; iface=$(ip route show default | awk "NR==1 {print \$5}"); ip -brief address show "$iface"; systemctl is-active NetworkManager sddm; loginctl list-sessions --no-legend'
    ;;
  now)
    remote 'printf "applications:\n"; ps -u "$(id -u)" -o comm= | sort -u | grep -E "^(chrome|firefox|konsole|mpv|stremio|vlc)$" || true; printf "audio-streams:\n"; XDG_RUNTIME_DIR=/run/user/1000 wpctl status | awk "found && /^Video/{exit} /Streams:/{found=1} found"'
    ;;
  screenshot)
    shift
    (($# <= 1)) || { echo 'tvctl: screenshot accepts at most one output path' >&2; exit 64; }
    output=${1:-"$PWD/tv-screenshot-$(date -u +%Y%m%d-%H%M%S).png"}
    [[ $output == /* ]] || output="$PWD/$output"
    [[ ! -d $output ]] || { echo "tvctl: output path is a directory: $output" >&2; exit 64; }
    remote_screenshot_path="/tmp/tvctl-screenshot-$$-$RANDOM.png"
    trap cleanup_screenshot EXIT INT TERM
    remote_argv env XDG_RUNTIME_DIR=/run/user/1000 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus WAYLAND_DISPLAY=wayland-0 DISPLAY=:1 spectacle -b -n -o "$remote_screenshot_path"
    timeout 60 scp -q "${batch_opts[@]}" "$target:$remote_screenshot_path" "$output"
    [[ -s $output ]] || { echo "tvctl: screenshot copy is empty: $output" >&2; exit 1; }
    cleanup_screenshot
    trap - EXIT INT TERM
    printf '%s\n' "$output"
    ;;
  tablet)
    remote '/usr/bin/adb start-server >/dev/null; /usr/bin/adb devices -l'
    ;;
  kill)
    shift
    (($# == 1)) || { echo 'tvctl: kill requires one process name/pattern' >&2; exit 64; }
    # Pattern travels over stdin so pgrep/pkill -f can never match our own
    # remote ssh shell (a pattern literal in the remote cmdline kills the
    # session itself -> exit 255).
    printf '%s' "$1" | remote 'pat=$(cat); pids=$(pgrep -f -i -- "$pat") || { echo "no match: $pat"; exit 1; }
      kill $pids 2>/dev/null; sleep 1
      left=$(pgrep -f -i -- "$pat") && { kill -9 $left 2>/dev/null; sleep 1; }
      if pgrep -f -i -- "$pat" >/dev/null; then echo "still running: $pat"; exit 1; else echo "killed: $pat"; fi'
    ;;
  run)
    shift
    [[ ${1:-} == -- ]] && shift
    (($#)) || { echo 'tvctl: missing command' >&2; exit 64; }
    remote_argv "$@"
    ;;
  shell)
    shift
    (($# == 1)) || { echo 'tvctl: shell requires one quoted command' >&2; exit 64; }
    remote "$1"
    ;;
  notify)
    shift
    (($#)) || { echo 'tvctl: missing message' >&2; exit 64; }
    msg=$*
    remote_argv env XDG_RUNTIME_DIR=/run/user/1000 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus notify-send -a tvctl 'Remote message' "$msg"
    ;;
  request)
    shift
    printf 'tvctl: interactive-control request recorded; no TV notification was sent.\n'
    ;;
  open)
    shift
    (($# == 1)) || { echo 'tvctl: open requires one URL' >&2; exit 64; }
    url=$1
    [[ $url =~ ^https?:// ]] || { echo 'tvctl: open accepts only http(s) URLs' >&2; exit 64; }
    remote_argv env XDG_RUNTIME_DIR=/run/user/1000 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus WAYLAND_DISPLAY=wayland-0 DISPLAY=:1 flatpak run com.google.Chrome "$url" || remote_argv env XDG_RUNTIME_DIR=/run/user/1000 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus WAYLAND_DISPLAY=wayland-0 DISPLAY=:1 xdg-open "$url"
    ;;
  lock) remote loginctl lock-sessions ;;
  reboot)
    # Clean reboot via PID1; if the manager/D-Bus is wedged, fall back to
    # systemctl -ff (direct reboot(2) syscall, no PID1 involvement).
    remote 'sudo -n systemctl reboot' || remote 'sudo -n systemctl reboot -ff' || remote 'sudo -n reboot -f'
    ;;
  shutdown) remote sudo -n systemctl poweroff ;;
  setup-key)
    install -d -m 700 "$HOME/.ssh"
    [[ -f "$identity" ]] || ssh-keygen -t ed25519 -f "$identity" -C 'tvctl access to tv'
    ssh-copy-id -i "$identity.pub" "$target"
    ;;
  ssh) exec ssh "${ssh_opts[@]}" "$target" ;;
  *) echo "tvctl: unknown command: $1" >&2; usage >&2; exit 64 ;;
esac
