#!/usr/bin/env bash
set -euo pipefail

host=${TV_HOST:-192.168.1.12}
user=${TV_USER:-olafurbui}
identity=${TV_IDENTITY:-$HOME/.ssh/id_rsa}
timeout_s=${TV_CONNECT_TIMEOUT:-5}
cmd_timeout=${TV_CMD_TIMEOUT:-30}
target="$user@$host"

# TV Kit deployment settings
kit_dir=${TV_KIT_DIR:-$HOME/Projects/tv-kit}
kit_home=".tv-kit"               # app home on the TV, relative to $HOME
kit_remote_dir="$kit_home/src"   # synced source tree on the TV
titan=${TITAN_HOST:-olafurbui@192.168.1.10}
kit_runtime="XDG_RUNTIME_DIR=/run/user/1000"
kit_units=(tvserverd.service tv-remote.service tv-frame.service tvserverd-radioscraper.service tvserverd-radioscraper.timer)
kit_enable=(tvserverd.service tv-remote.service tv-frame.service tvserverd-radioscraper.timer)
kit_hot=(tvserverd.service tv-remote.service) # restarted when deps change
kit_stale_units=(tv-dashboard-dev.service tv-remote-dev.service tv-dashboard.service tv-kiosk.service)
kit_excludes=(.git node_modules data artifacts .deploy-stage .pi-subagents dist '*.log' '*.sqlite' '*.sqlite-shm' '*.sqlite-wal')
test_home=${TV_TEST_HOME:-$HOME/.tv-kit-test}
test_host=${TV_TEST_HOST:-192.168.1.10}
test_server_port=${TV_TEST_SERVER_PORT:-3220}
test_remote_port=${TV_TEST_REMOTE_PORT:-3222}
test_rpc_port=${TV_TEST_RPC_PORT:-3223}
test_db="$test_home/data/tv-kit.sqlite"
test_env="$test_home/env"
test_server_unit=tvserverd-test.service
test_remote_unit=tv-remote-test.service

ssh_opts=(-o ConnectTimeout="$timeout_s" -o ServerAliveInterval=5 -o ServerAliveCountMax=2 -o ControlMaster=no)
[[ -f "$identity" ]] && ssh_opts+=(-i "$identity" -o IdentitiesOnly=yes)
batch_opts=("${ssh_opts[@]}" -o BatchMode=yes)

usage() {
  cat <<'EOF'
Usage: tvctl COMMAND [ARGS]

Device:
  doctor                 Check route, SSH, host identity, and KDE session
  snapshot               One-connection JSON health, playback, load, and process snapshot
  status                 Show uptime, network, SDDM, and logged-in sessions
  now                    Show open GUI/media apps and active audio streams
  screenshot [FILE]      Capture the current KDE screen to a local PNG
  tablet                 Show the permanent Android tablet's ADB status
  run -- COMMAND [ARGS]  Run an argv-safe remote command
  kill PATTERN           Kill processes matching PATTERN (TERM then KILL, verified)
  shell COMMAND          Run an explicit remote shell command
  notify MESSAGE         Display a KDE desktop notification
  request [REASON]       Record an interactive-control request locally
  open URL               Open URL in the active TV browser session
  lock                   Lock the active KDE session
  reboot                 Reboot the TV
  shutdown               Power off the TV
  setup-key              Create/install the SSH key interactively
  ssh                    Open an interactive SSH session

TV Kit (no-build hot-reload deployment; source of truth: ~/Projects/tv-kit):
  kit sync [MESSAGE]     Fast deploy: rsync source to the TV; bun --watch and
                         Vite HMR pick edits up instantly. Installs deps/units
                         only when they changed. Fires background git archive.
  kit setup              One-time/repair: bun runtime, linger, service units,
                         legacy /opt deployment cleanup, DB migration, then sync
  kit golfbox-env [FILE] Atomically install a protected GolfBox .env on the TV
  kit status             Boot-enabled/active service states and health endpoints
  kit verify             Require enabled+active services, HTTP health, and WS ping/pong
  kit check [warnings]   Run TV-local tests and TypeScript/Svelte checks;
                         warnings shows all Svelte diagnostics
  kit frame build        Build the native Qt/QML TV Frame locally on Titan
  kit frame test         Build and run the TV Frame test suite on Titan
  kit frame deploy       Sync, build on Titan, push binary, switch from Chrome, verify
  kit frame health       Require an active, connected TV Frame service
  kit frame verify       Health check plus one saved physical TV screenshot
  kit fullscreen [MODE]  Show ruv (default), ruv2, or off in fullscreen
  kit playback COMMAND   Read/control playback: state, stop, play, search QUERY,
                         or deildu ITEM_ID
  kit epg [status|sync]  Inspect or force the TV-local RÚV EPG sync
  kit restart [UNIT...]  Restart TV Kit services
  kit logs [UNIT] [N]    Show recent journal lines (default tvserverd, 50)
  kit archive [MESSAGE]  Commit and push the tree from Titan (archiving only)
  kit test deploy        Clone the TV DB and deploy isolated test services on Titan
  kit test refresh       Replace the clone and restart the Titan test services
  kit test status        Show Titan test services, endpoints, and database summary
  kit test verify        Require healthy Titan test services and cloned real data
  kit test logs [server|remote] [N]
                         Show Titan test service logs
  kit test stop          Stop the isolated Titan test services

Direct mpv (read/change tracks over IPC without reloading playback):
  mpv tracks             List audio/subtitle tracks and current selections
  mpv audio ID|auto|off  Select an audio track
  mpv subtitle ID|auto|off
                         Select a subtitle track

Deildu catalog (read-only, secret-safe):
  deildu search QUERY    Search catalog rows
  deildu item ID         Show one catalog/download row as JSON
  deildu links ID        Show safe detail, stream, and local torrent links
  deildu files ID        List files in cached torrent metadata

Public torrents (multi-source: ThePirateBay/apibay, Knaben, 1337x, EZTV):
  public search QUERY    Live multi-source search; dedup, sort by seeders, persist
  public list [N]        Read-only DB sample sorted by seeders (default 30)
  public scrape          Trigger concurrent scrape + clean + enrich
  public state           Show scrape run state
  public play HASH       Play a public torrent (40-hex info hash); verifies frames
  public stop            Stop playback

Environment: TV_HOST, TV_USER, TV_IDENTITY, TV_CONNECT_TIMEOUT, TV_CMD_TIMEOUT,
             TV_KIT_DIR, TITAN_HOST, TV_FRAME_BUILD_JOBS, TV_TEST_HOME,
             TV_TEST_HOST, TV_TEST_SERVER_PORT, TV_TEST_REMOTE_PORT,
             TV_TEST_RPC_PORT
EOF
}

remote() { timeout "$cmd_timeout" ssh "${batch_opts[@]}" "$target" "$@"; }
remote_long() { local t=$1; shift; timeout "$t" ssh "${batch_opts[@]}" "$target" "$@"; }

remote_argv() {
  local quoted= arg
  for arg in "$@"; do
    printf -v arg '%q' "$arg"
    quoted+="${quoted:+ }$arg"
  done
  remote "$quoted"
}

kit_systemctl() { remote "env $kit_runtime systemctl --user $*"; }

kit_orphan_cleanup() {
  remote 'flatpak kill com.google.Chrome >/dev/null 2>&1 || true; pkill -9 -f /app/extra/[c]hrome >/dev/null 2>&1 || true; pkill -9 -x aria2c >/dev/null 2>&1 || true; pkill -9 -x mpv >/dev/null 2>&1 || true; pkill -9 -f TVCTL_PLAYBACK_[V]ALUE >/dev/null 2>&1 || true'
}


kit_health() {
  local ok=1 url
  for url in "http://$host:3110/health" "http://$host:3112/"; do
    local tries=0
    until curl -fsS --max-time 3 "$url" >/dev/null 2>&1; do
      ((++tries >= 8)) && { echo "health FAIL $url"; ok=0; break; }
      sleep 1
    done
    ((tries < 8)) && echo "health ok   $url"
  done
  ((ok))
}

kit_rsync() {
  local ex=() e
  for e in "${kit_excludes[@]}"; do ex+=(--exclude "$e"); done
  timeout 120 rsync -az --delete --timeout=30 \
    -e "ssh ${batch_opts[*]}" \
    "${ex[@]}" "$kit_dir"/ "$target:$kit_remote_dir"/
}

kit_deps() {
  # Install dependencies on the TV only when lockfile/manifests changed.
  remote_long 420 "cd $kit_remote_dir && \
    new=\$(cat bun.lock package.json apps/*/package.json packages/*/package.json 2>/dev/null | sha256sum | cut -d' ' -f1); \
    old=\$(cat ~/$kit_home/deps.sha 2>/dev/null || true); \
    if [ \"\$new\" != \"\$old\" ]; then \
      ~/.bun/bin/bun install --frozen-lockfile && printf '%s' \"\$new\" > ~/$kit_home/deps.sha && echo deps-installed; \
    else echo deps-unchanged; fi"
}

kit_units_install() {
  # Copy changed unit files; print names of units that changed.
  local list=${kit_units[*]}
  remote "cd $kit_remote_dir && mkdir -p ~/.config/systemd/user && changed=; \
    for u in $list; do \
      if ! cmp -s ops/systemd/user/\$u ~/.config/systemd/user/\$u 2>/dev/null; then \
        cp ops/systemd/user/\$u ~/.config/systemd/user/\$u && changed=\"\$changed \$u\"; \
      fi; \
    done; \
    rm -f $(printf '~/.config/systemd/user/%s ' "${kit_stale_units[@]}"); \
    [ -z \"\$changed\" ] || env $kit_runtime systemctl --user daemon-reload; \
    echo \"changed:\$changed\""
}

kit_archive() {
  local message=${1:-"Archive TV Kit $(date -u +'%Y-%m-%dT%H:%M:%SZ')"} q
  printf -v q '%q' "$message"
  if [[ -d $kit_dir/.git ]]; then
    (cd "$kit_dir" && git add -A && { git diff --cached --quiet || git commit -m "$message"; } && git push origin HEAD:main)
  else
    timeout 90 ssh "${batch_opts[@]}" "$titan" \
      "cd ~/Projects/tv-kit && git add -A && { git diff --cached --quiet || git commit -m $q; } && git push origin HEAD:main"
  fi
}

kit_sync() {
  local message=${1:-}
  echo "== cleanup orphaned players"
  kit_orphan_cleanup
  echo "== sync source -> $target:$kit_remote_dir"
  kit_rsync
  echo "== dependencies"
  local deps units
  deps=$(kit_deps); echo "$deps"
  echo "== service units"
  units=$(kit_units_install); echo "$units"
  kit_systemctl "enable --now ${kit_enable[*]}" >/dev/null 2>&1 || true
  local restart=()
  [[ $deps == *deps-installed* ]] && restart+=("${kit_hot[@]}")
  if [[ $units == *changed:*[a-z]* ]]; then
    # Restart only long-running units; oneshots (radioscraper) block a
    # blocking restart for minutes and are driven by their timer instead.
    local u e
    for u in ${units#*changed:}; do
      for e in "${kit_enable[@]}"; do [[ $u == "$e" ]] && restart+=("$u"); done
    done
  fi
  if ((${#restart[@]})); then
    local uniq; uniq=$(printf '%s\n' "${restart[@]}" | sort -u | tr '\n' ' ')
    echo "== restart: $uniq"
    kit_systemctl "restart $uniq"
  else
    echo "== no restarts needed (hot reload picks up the synced files)"
  fi
  echo "== health"
  kit_health
  echo "== archive (background, non-blocking)"
  (kit_archive "$message" >>/tmp/tv-kit-archive.log 2>&1 && echo "archive ok $(date -u +%FT%TZ)" >>/tmp/tv-kit-archive.log || echo "archive FAILED $(date -u +%FT%TZ)" >>/tmp/tv-kit-archive.log) &
  disown
  echo "done"
}

kit_setup() {
  echo "== bun runtime"
  remote_long 180 'command -v ~/.bun/bin/bun >/dev/null || curl -fsSL https://bun.sh/install | bash >/dev/null; ~/.bun/bin/bun --version'
  echo "== runtime tools + Qt runtime libs on the TV (build tools stay on Titan)"
  remote_long 180 'command -v rsync >/dev/null || sudo -n pacman -S --needed --noconfirm rsync >/dev/null; command -v aria2c >/dev/null || sudo -n pacman -S --needed --noconfirm aria2 >/dev/null; command -v mpv >/dev/null || sudo -n pacman -S --needed --noconfirm mpv >/dev/null; pacman -Q qt6-declarative qt6-websockets mpvqt >/dev/null 2>&1 || sudo -n pacman -S --needed --noconfirm qt6-declarative qt6-websockets mpvqt >/dev/null; sudo -n pacman -Rns --noconfirm cmake ninja >/dev/null 2>&1 || true; echo runtime-tools-present'
  echo "== retire dead NFS automount at ~/Projects (replaced by tvctl rsync)"
  remote 'if grep -q "^100.88.0.9:/home/olafurbui/Projects" /etc/fstab; then \
      sudo -n cp /etc/fstab /etc/fstab.bak-tvkit; \
      sudo -n sed -i "s|^100.88.0.9:/home/olafurbui/Projects|#&|" /etc/fstab && echo fstab-nfs-disabled; \
    else echo fstab-already-clean; fi'
  remote 'sudo -n systemctl stop --no-block home-olafurbui-Projects.automount 2>/dev/null; sudo -n umount -fl /home/olafurbui/Projects 2>/dev/null; true' || true
  remote 'timeout 20 sudo -n systemctl daemon-reload && echo reload-ok' || echo 'reload skipped (busy manager); rerun kit setup later'
  echo "== linger + legacy cleanup (discrete bounded steps)"
  remote "sudo -n loginctl enable-linger $user && echo linger-ok"
  remote 'sudo -n systemctl kill -s SIGKILL tvserverd.service 2>/dev/null; sudo -n rm -f /etc/systemd/system/tvserverd.service /etc/systemd/system/multi-user.target.wants/tvserverd.service; echo legacy-unit-removed' || true
  remote "mkdir -p ~/$kit_home/data ~/$kit_remote_dir && echo dirs-ok"
  remote "if [ -f /var/lib/tv-kit/tv-kit.sqlite ] && [ ! -f ~/$kit_home/data/tv-kit.sqlite ]; then sudo -n cp -a /var/lib/tv-kit/tv-kit.sqlite* ~/$kit_home/data/ && sudo -n chown $user:$user ~/$kit_home/data/tv-kit.sqlite* && echo db-migrated; else echo db-migration-not-needed; fi"
  remote 'sudo -n rm -rf /opt/tv-kit /opt/tv-kit-dev /etc/tv-kit && echo legacy-dirs-removed'
  echo "== TV-local settings overrides (~/$kit_home/env)"
  remote "[ -f ~/$kit_home/env ] || install -m 0600 /dev/null ~/$kit_home/env; \
    grep -q '^TV_KIT_DB=' ~/$kit_home/env || printf 'TV_KIT_DB=%s/$kit_home/data/tv-kit.sqlite\n' \"\$HOME\" >> ~/$kit_home/env; \
    grep -q '^TORRENT_MEDIA_DIR=' ~/$kit_home/env || printf 'TORRENT_MEDIA_DIR=%s/$kit_home/data/torrents\n' \"\$HOME\" >> ~/$kit_home/env; \
    chmod 0600 ~/$kit_home/env; echo env-ok"
  echo "== seed database if the TV has none"
  if ! remote "test -f ~/$kit_home/data/tv-kit.sqlite"; then
    if [[ -f $kit_dir/data/tv-kit.sqlite ]]; then
      timeout 60 scp -q "${batch_opts[@]}" "$kit_dir/data/tv-kit.sqlite" "$target:$kit_home/data/tv-kit.sqlite"
      echo "db-seeded-from-local"
    else
      echo "no local database snapshot; server will create a fresh one"
    fi
  else
    echo "db-present"
  fi
  kit_sync "${1:-}"
}

kit_golfbox_env() {
  (($# <= 1)) || { echo 'tvctl: kit golfbox-env accepts at most one source file' >&2; exit 64; }
  local source=${1:-$HOME/.config/golfbox/.env} remote_tmp="$kit_home/.env.tmp.$$"
  [[ -f $source ]] || { echo "tvctl: GolfBox .env not found: $source" >&2; exit 66; }
  timeout 60 scp -q "${batch_opts[@]}" "$source" "$target:$remote_tmp"
  remote "chmod 0600 ~/$remote_tmp && mv ~/$remote_tmp ~/$kit_home/.env"
  echo "golfbox-env-installed ~/$kit_home/.env mode=0600"
}

kit_status() {
  echo "== boot enabled"
  kit_systemctl "is-enabled ${kit_enable[*]}" || true
  echo "== active"
  kit_systemctl "list-units --no-pager --no-legend ${kit_units[*]}" || true
  echo "== health"
  kit_health || true
}

kit_verify() {
  kit_systemctl "is-enabled --quiet ${kit_enable[*]}"
  kit_systemctl "is-active --quiet ${kit_enable[*]}"
  kit_health
  local script='const fail = message => { console.error(message); try { ws.close(); } catch {} process.exit(1); };
const ws = new WebSocket("ws://127.0.0.1:3110/ws?client=verify", { headers: { Origin: "http://127.0.0.1:3112" } });
const timer = setTimeout(() => fail("websocket ping timeout"), 5000);
ws.onerror = () => fail("websocket connection failed");
ws.onopen = () => ws.send(JSON.stringify({ type: "ping" }));
ws.onmessage = event => { if (JSON.parse(String(event.data)).type !== "pong") return; clearTimeout(timer); console.log("websocket ping/pong ok"); ws.close(); };'
  remote_argv ~/.bun/bin/bun -e "$script"
  echo "services enabled+active"
}

kit_restart() {
  local units=("$@")
  ((${#units[@]})) || units=("${kit_enable[@]}")
  local unit
  for unit in "${units[@]}"; do
    [[ $unit =~ ^[A-Za-z0-9@_.:-]+$ ]] || { echo "tvctl: invalid systemd unit: $unit" >&2; return 64; }
  done
  kit_systemctl "daemon-reload"
  kit_systemctl "restart ${units[*]}"
  kit_status
}

kit_logs() {
  local unit=${1:-tvserverd.service} lines=${2:-50}
  (($# <= 2)) || { echo 'tvctl: kit logs accepts UNIT and line count' >&2; return 64; }
  [[ $unit =~ ^[A-Za-z0-9@_.:-]+$ ]] || { echo "tvctl: invalid systemd unit: $unit" >&2; return 64; }
  [[ $lines =~ ^[1-9][0-9]*$ ]] && ((lines <= 1000)) || { echo 'tvctl: log line count must be 1..1000' >&2; return 64; }
  kit_systemctl "status --no-pager -n $lines $unit" || \
    remote "env $kit_runtime journalctl --user -u $unit -n $lines --no-pager"
}

kit_check() {
  local warnings=${1:-}
  [[ -z $warnings || $warnings == warnings ]] || { echo 'tvctl: kit check accepts warnings only' >&2; return 64; }
  local svelte_check='~/.bun/bin/bun x svelte-check --threshold error --tsconfig ./tsconfig.svelte.json'
  [[ $warnings == warnings ]] && svelte_check='~/.bun/bin/bun x svelte-check --tsconfig ./tsconfig.svelte.json'
  remote_long 300 "cd $kit_remote_dir && \
    ~/.bun/bin/bun test && \
    ~/.bun/bin/bun x tsc -p tsconfig.json --noEmit && \
    $svelte_check"
}

kit_test_validate() {
  [[ $test_home == /* ]] || { echo 'tvctl: TV_TEST_HOME must be an absolute path' >&2; return 64; }
  local port
  for port in "$test_server_port" "$test_remote_port" "$test_rpc_port"; do
    [[ $port =~ ^[0-9]+$ ]] && ((port >= 1024 && port <= 65535)) || {
      echo 'tvctl: TV_TEST_*_PORT values must be integers in 1024..65535' >&2
      return 64
    }
  done
  [[ $test_server_port != "$test_remote_port" &&
     $test_server_port != "$test_rpc_port" &&
     $test_remote_port != "$test_rpc_port" ]] || {
    echo 'tvctl: TV_TEST_*_PORT values must be distinct' >&2
    return 64
  }
  [[ -f $kit_dir/package.json ]] || { echo "tvctl: TV Kit source missing at $kit_dir" >&2; return 66; }
}

kit_test_ports_free() {
  command -v ss >/dev/null || { echo 'tvctl: ss is required on Titan' >&2; return 69; }
  local port
  for port in "$test_server_port" "$test_remote_port" "$test_rpc_port"; do
    if ss -H -ltn "sport = :$port" | grep -q .; then
      echo "tvctl: Titan test port is already in use: $port" >&2
      return 69
    fi
  done
}

kit_test_write_env() {
  mkdir -p "$test_home/data/torrents"
  chmod 0700 "$test_home" "$test_home/data" "$test_home/data/torrents"
  local tmp="$test_env.tmp.$$"
  cat >"$tmp" <<EOF
PORT=$test_server_port
VITE_TVSERVER_URL=http://$test_host:$test_server_port
TV_KIT_DB=$test_db
TORRENT_MEDIA_DIR=$test_home/data/torrents
DEILDU_STREAM_RPC_PORT=$test_rpc_port
TV_ALLOWED_ORIGINS=http://$test_host:$test_remote_port,http://127.0.0.1:$test_remote_port
DEILDU_SCHEDULER_START_DELAY_MS=3600000
PUBLIC_TORRENT_SCHEDULER_START_DELAY_MS=3600000
RUV_SCHEDULER_START_DELAY_MS=3600000
GOLFBOX_SCHEDULER_ENABLED=false
EOF
  chmod 0600 "$tmp"
  mv -f "$tmp" "$test_env"
}

kit_test_clone_db() {
  local remote_snapshot="/tmp/tv-kit-test-${USER}-$$.sqlite"
  local local_snapshot="$test_db.tmp.$$"
  mkdir -p "$test_home/data"
  chmod 0700 "$test_home" "$test_home/data"
  echo "== online backup TV database -> Titan test clone"
  if ! remote_argv sqlite3 "/home/$user/$kit_home/data/tv-kit.sqlite" \
    ".timeout 30000" ".backup '$remote_snapshot'"; then
    remote_argv rm -f "$remote_snapshot" >/dev/null 2>&1 || true
    return 1
  fi
  if ! timeout 120 scp -q "${batch_opts[@]}" "$target:$remote_snapshot" "$local_snapshot"; then
    remote_argv rm -f "$remote_snapshot" >/dev/null 2>&1 || true
    rm -f "$local_snapshot"
    return 1
  fi
  remote_argv rm -f "$remote_snapshot" >/dev/null
  [[ $(sqlite3 "$local_snapshot" 'PRAGMA integrity_check;') == ok ]] || {
    echo 'tvctl: cloned database failed SQLite integrity_check' >&2
    rm -f "$local_snapshot"
    return 74
  }
  chmod 0600 "$local_snapshot"
  mv -f "$local_snapshot" "$test_db"
}

kit_test_stop() {
  (($# == 0)) || { echo 'tvctl: kit test stop accepts no arguments' >&2; return 64; }
  systemctl --user stop "$test_server_unit" "$test_remote_unit" >/dev/null 2>&1 || true
  systemctl --user reset-failed "$test_server_unit" "$test_remote_unit" >/dev/null 2>&1 || true
  echo "Titan test services stopped"
}

kit_test_start_unit() {
  local unit=$1 description=$2
  shift 2
  systemd-run --user --unit="$unit" --collect \
    --description="$description" \
    --working-directory="$kit_dir" \
    --property=Restart=on-failure \
    --property=RestartSec=2 \
    --property=TimeoutStopSec=5 \
    --property=KillMode=control-group \
    --property=SendSIGKILL=true \
    --property="EnvironmentFile=$test_env" \
    --property=UMask=0077 \
    --property=NoNewPrivileges=true \
    "$@"
}

kit_test_wait_http() {
  local url=$1 tries=0
  until curl -fsS --max-time 3 "$url" >/dev/null 2>&1; do
    ((++tries >= 30)) && { echo "tvctl: health timeout: $url" >&2; return 1; }
    sleep 1
  done
  echo "health ok $url"
}

kit_test_verify() {
  (($# == 0)) || { echo 'tvctl: kit test verify accepts no arguments' >&2; return 64; }
  kit_test_validate
  systemctl --user is-active --quiet "$test_server_unit" "$test_remote_unit"
  kit_test_wait_http "http://$test_host:$test_server_port/health"
  kit_test_wait_http "http://$test_host:$test_remote_port/"
  [[ -f $test_db ]] || { echo "tvctl: test database missing: $test_db" >&2; return 66; }
  [[ $(sqlite3 "$test_db" 'PRAGMA integrity_check;') == ok ]] || {
    echo 'tvctl: Titan test database integrity check failed' >&2
    return 74
  }
  sqlite3 -json "$test_db" \
    "SELECT
       (SELECT max(version) FROM schema_migrations) AS schema_version,
       (SELECT count(*) FROM deildu_items) AS deildu_items,
       (SELECT count(*) FROM ruv_programs) AS ruv_programs,
       (SELECT count(*) FROM radio_stations) AS radio_stations,
       (SELECT count(*) FROM public_torrents) AS public_torrents,
       'ok' AS integrity;"
}

kit_test_deploy() {
  (($# == 0)) || { echo 'tvctl: kit test deploy accepts no arguments' >&2; return 64; }
  kit_test_validate
  local bun_bin
  bun_bin=${BUN_BIN:-$(command -v bun)}
  [[ -x $bun_bin ]] || { echo 'tvctl: Bun is required on Titan' >&2; return 69; }
  command -v sqlite3 >/dev/null || { echo 'tvctl: sqlite3 is required on Titan' >&2; return 69; }
  command -v systemd-run >/dev/null || { echo 'tvctl: systemd-run is required on Titan' >&2; return 69; }
  command -v scp >/dev/null || { echo 'tvctl: scp is required on Titan' >&2; return 69; }
  kit_test_stop
  kit_test_ports_free
  kit_test_clone_db
  kit_test_write_env
  if [[ ! -d $kit_dir/node_modules ]]; then
    echo '== install Titan dependencies'
    (cd "$kit_dir" && "$bun_bin" install --frozen-lockfile)
  fi
  echo '== start isolated Titan services'
  kit_test_start_unit "$test_server_unit" 'TV Kit Titan test server' \
    "$bun_bin" --watch apps/server/src/index.ts
  kit_test_start_unit "$test_remote_unit" 'TV Kit Titan test remote' \
    "$bun_bin" --cwd apps/remote dev --host 0.0.0.0 --port "$test_remote_port"
