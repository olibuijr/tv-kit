kit_frame_build_dir="$HOME/.cache/tv-kit/frame-build"

kit_frame_build() {
  (($# == 0)) || { echo 'tvctl: kit frame build accepts no arguments' >&2; return 64; }
  local jobs=${TV_FRAME_BUILD_JOBS:-$(nproc)}
  [[ $jobs =~ ^[0-9]+$ && $jobs -ge 1 ]] || { echo 'tvctl: TV_FRAME_BUILD_JOBS must be a positive integer' >&2; return 64; }
  [[ -f $kit_dir/apps/tv-frame/CMakeLists.txt ]] || { echo 'tvctl: native frame source is missing' >&2; return 66; }
