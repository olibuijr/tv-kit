  for tool in cmake ninja g++; do
    command -v "$tool" >/dev/null || { echo "tvctl: $tool is missing on Titan; install it locally (never build on the TV)" >&2; return 69; }
  done
  cmake -S "$kit_dir/apps/tv-frame" -B "$kit_frame_build_dir" -G Ninja -DCMAKE_BUILD_TYPE=RelWithDebInfo
  cmake --build "$kit_frame_build_dir" --parallel "$jobs"
}

