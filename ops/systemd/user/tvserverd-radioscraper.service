[Unit]
Description=Refresh and validate Homeboard radio stations
Wants=network-online.target
After=network-online.target tvserverd.service

[Service]
Type=oneshot
TimeoutStartSec=2min
WorkingDirectory=%h/Projects/tv-kit
EnvironmentFile=%h/Projects/tv-kit/.env
Environment=PATH=%h/.bun/bin:/usr/local/bin:/usr/bin
ExecStart=/usr/bin/env bun apps/server/src/radioscraper.ts
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
SyslogIdentifier=tvserverd-radioscraper
