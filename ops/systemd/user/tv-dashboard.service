[Unit]
Description=TV Kit dashboard (Vite dev server, hot module reload)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.tv-kit/src
EnvironmentFile=-%h/.tv-kit/env
Environment=PATH=%h/.bun/bin:/usr/local/bin:/usr/bin
ExecStart=/usr/bin/env bun run dev:dashboard
Restart=always
RestartSec=2
TimeoutStopSec=5
NoNewPrivileges=true
PrivateTmp=true
SyslogIdentifier=tv-dashboard

[Install]
WantedBy=default.target
