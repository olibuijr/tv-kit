[Unit]
Description=TV Kit dashboard static client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/tv-kit/dashboard
ExecStart=/usr/bin/python -m http.server 3111 --bind 0.0.0.0
Restart=always
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
