PORT=3110
# Dev default; on the TV this is overridden by ~/.tv-kit/env to
# /home/olafurbui/.tv-kit/data/tv-kit.sqlite (the live source of truth).
TV_KIT_DB=/home/olafurbui/Projects/tv-kit/data/tv-kit.sqlite
TORRENT_MEDIA_DIR=/home/olafurbui/Projects/tv-kit/data/torrents
DEILDU_BASE_URL=https://deildu.net
DEILDU_USERNAME=
DEILDU_PASSWORD=
DEILDU_PASSKEY=
DEILDU_USER_AGENT=tvserverd-deildu/1.0
DEILDU_SYNC_INTERVAL_MS=21600000
DEILDU_SCHEDULER_START_DELAY_MS=20000
DEILDU_SCRAPE_PAGES=2
DEILDU_SCRAPE_PACING_MS=500
DEILDU_FETCH_TIMEOUT_MS=30000
DEILDU_ARIA2_BIN=/usr/bin/aria2c
DEILDU_STREAM_RPC_PORT=3113
DEILDU_STREAM_START_TIMEOUT_MS=60000
DEILDU_STREAM_RANGE_WAIT_MS=60000
DEILDU_STREAM_BUFFER_BYTES=16777216
PUBLIC_TORRENT_API_URL=https://api.knaben.org/v1
PUBLIC_TORRENT_USER_AGENT=tvserverd-public-torrents/1.0
PUBLIC_TORRENT_SYNC_INTERVAL_MS=21600000
PUBLIC_TORRENT_SCHEDULER_START_DELAY_MS=30000
PUBLIC_TORRENT_FETCH_TIMEOUT_MS=30000
PUBLIC_TORRENT_PAGE_SIZE=300
PUBLIC_TORRENT_MAX_PAGES=40
PUBLIC_TORRENT_LOOKBACK_SECONDS=86400
PUBLIC_TORRENT_SCRAPE_PACING_MS=250
PUBLIC_TORRENT_CLEANUP_LIMIT=500
# Knaben movie/TV leaf categories: TV HD/SD/UHD/foreign, movie HD/SD/UHD/foreign.
PUBLIC_TORRENT_CATEGORIES=2001000,2002000,2003000,2005000,3001000,3002000,3003000,3005000
RADIO_SOURCE_URL=https://bakendi.spilarinn.is/api/stations/
RADIO_SOURCE_NAME=spilarinn.is
RADIO_SYNC_INTERVAL_MS=86400000
RADIO_STREAM_TIMEOUT_MS=8000
RADIO_SCRAPE_CONCURRENCY=6
PODCAST_SYNC_INTERVAL_MS=3600000
PODCAST_FETCH_TIMEOUT_MS=20000
PODCAST_EPISODE_LIMIT=50
SOLAR_API_URL=https://api.sunrise-sunset.org/v2
SOLAR_CACHE_MS=21600000
# Public Rastimar endpoint documented by olibuijr/golfkort.
GOLF_TEE_TIMES_URL=https://rastimar.golf.is/api/courses
GOLF_TEE_TIMES_CACHE_MS=300000
GOLF_TEE_TIMES_FETCH_TIMEOUT_MS=15000
# Scheduled authenticated GolfBox sync. GOLFBOX_USERNAME/GOLFBOX_PASSWORD live
# only in this separate protected .env (mode 0600), never in this example.
GOLFBOX_CTL_BIN=/home/olafurbui/.tv-kit/src/scripts/golfboxctl
GOLFBOX_ENV_FILE=/home/olafurbui/.tv-kit/.env
# Person, course resource, horizon, interval, and task title are SQLite settings.
GOLFBOX_SCHEDULER_START_DELAY_MS=10000
GOLFBOX_TASK_TIMEOUT_MS=180000
RUV_API_BASE=https://api.ruv.is
RUV_LIVE_BASE=https://geo.spilari.ruv.is
RUV_EPG_BASE=https://muninn.ruv.is
RUV_SITE_BASE=https://www.ruv.is
RUV_SEARCH_URL=https://spilari.nyr.ruv.is/gql/
RUV_NEWS_CATEGORIES=,innlent,erlent,ithrottir,menning-og-daegurmal
RUV_EPG_DAYS_BACK=1
RUV_EPG_DAYS_FORWARD=10
RUV_SYNC_INTERVAL_MS=86400000
RUV_NEWS_SYNC_INTERVAL_MS=3600000
RUV_SCHEDULER_START_DELAY_MS=15000
RUV_SCHEDULER_POLL_MS=60000
RUV_CHILD_TIMEOUT_MS=900000
RUV_SCRAPE_CONCURRENCY=4
RUV_CATALOG_CONCURRENCY=4
RUV_FETCH_TIMEOUT_MS=30000
RUV_FETCH_RETRIES=3
RUV_USER_AGENT=tvserverd-ruvscraper/1.0
RUV_ARCHIVE_SEARCH_TERMS=a,á,b,d,ð,e,é,f,g,h,i,í,j,k,l,m,n,o,ó,p,r,s,t,u,ú,v,x,y,ý,þ,æ,ö
RUV_ARCHIVE_SEARCH_BATCH_SIZE=6
RUV_ARCHIVE_SEARCH_PACING_MS=1500
TV_ALLOWED_ORIGINS=http://192.168.1.12:3112,http://127.0.0.1:3112,http://127.0.0.1:3110
# Required by the local AirPlay/Miracast/Cast receiver adapter.
CAST_INGRESS_TOKEN=replace-with-a-long-random-token
# Local Titan OpenAI-compatible model. Keep the API key only in the protected TV env.
LOCAL_LLM_BASE_URL=http://192.168.1.10:8080/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=empero-ai/Qwythos-9B-v2-GGUF
LOCAL_LLM_TIMEOUT_MS=120000
# Optional TMDB enrichment; keep the key only in the protected TV env.
TMDB_API_KEY=
TMDB_API_BASE=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500
# mpv renders all playback embedded directly inside the native Qt TV Frame
# process (apps/tv-frame's MpvVideo item, via libmpv/mpvqt) — no server-side
# mpv process or env-configurable flags; decode/cache options are set in
# MpvVideo's constructor.
# Curated from SourceSplash's Iceland queries; rotate only verified Iceland imagery.
TV_FRAME_WALLPAPER_URLS=https://www.sourcesplash.com/i/089c6688bf1c,https://www.sourcesplash.com/i/bec339027660,https://www.sourcesplash.com/i/9d93e63a2d5e,https://www.sourcesplash.com/i/272a6c43b86d
TV_FRAME_WALLPAPER_ROTATION_MS=600000
HOME_LATITUDE=65.6833
HOME_LONGITUDE=-18.1
HOME_TIMEZONE=Atlantic/Reykjavik
HOME_LOCATION="Akureyri, Iceland"
# tvserverd runs on the TV (192.168.1.12); all clients connect there.
VITE_TVSERVER_URL=http://192.168.1.12:3110
VITE_CONTENT_REFRESH_MS=30000
GOLFBOX_SCHEDULER_ENABLED=false
DASHBOARD_PORT=3111
REMOTE_PORT=3112
# Titan-only disposable test deployment used by `tvctl kit test`.
TV_TEST_HOME=/home/olafurbui/.tv-kit-test
TV_TEST_HOST=192.168.1.10
TV_TEST_SERVER_PORT=3220
TV_TEST_REMOTE_PORT=3222
TV_TEST_RPC_PORT=3223
