PORT=3110
# Dev default; on the TV this is overridden by ~/.tv-kit/env to
# /home/olafurbui/.tv-kit/data/tv-kit.sqlite (the live source of truth).
TV_KIT_DB=/home/olafurbui/Projects/tv-kit/data/tv-kit.sqlite
TORRENT_MEDIA_DIR=/home/olafurbui/Projects/tv-kit/data/torrents
DEILDU_BASE_URL=https://deildu.net
DEILDU_USERNAME=
DEILDU_PASSWORD=
DEILDU_PASSKEY=
DEILDU_USER_AGENT=tvserverd-deildu/1.0
DEILDU_SYNC_INTERVAL_MS=21600000
DEILDU_SCHEDULER_START_DELAY_MS=20000
DEILDU_SCRAPE_PAGES=2
DEILDU_SCRAPE_PACING_MS=500
DEILDU_FETCH_TIMEOUT_MS=30000
DEILDU_ARIA2_BIN=/usr/bin/aria2c
DEILDU_STREAM_RPC_PORT=3113
DEILDU_STREAM_START_TIMEOUT_MS=60000
DEILDU_STREAM_RANGE_WAIT_MS=60000
DEILDU_STREAM_BUFFER_BYTES=16777216
RADIO_SOURCE_URL=https://bakendi.spilarinn.is/api/stations/
RADIO_SOURCE_NAME=spilarinn.is
RADIO_SYNC_INTERVAL_MS=86400000
RADIO_STREAM_TIMEOUT_MS=8000
