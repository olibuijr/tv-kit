TV_ALLOWED_ORIGINS=http://192.168.1.12:3111,http://192.168.1.12:3112,http://127.0.0.1:3111,http://127.0.0.1:3112
# Required by the local AirPlay/Miracast/Cast receiver adapter.
CAST_INGRESS_TOKEN=replace-with-a-long-random-token
# Local Titan OpenAI-compatible model. Keep the API key only in the protected TV env.
LOCAL_LLM_BASE_URL=http://192.168.1.10:8080/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=empero-ai/Qwythos-9B-v2-GGUF
LOCAL_LLM_TIMEOUT_MS=120000
# Optional TMDB enrichment; keep the key only in the protected TV env.
TMDB_API_KEY=
TMDB_API_BASE=https://api.themoviedb.org/3
HOME_LATITUDE=65.6833
HOME_LONGITUDE=-18.1
HOME_TIMEZONE=Atlantic/Reykjavik
